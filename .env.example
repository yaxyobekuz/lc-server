NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URL=mongodb://127.0.0.1:27017/bayyina

# JWT
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookie
COOKIE_SECRET=replace_me_cookie
COOKIE_DOMAIN=localhost

# CORS - bir nechta domen vergul bilan ajratiladi (birinchisi asosiy).
# Barcha domenga ruxsat berish uchun: CLIENT_URL=*
CLIENT_URL=http://localhost:5173,http://localhost:3000

# Telegram bot
TELEGRAM_BOT_TOKEN=replace_me_bot_token
TELEGRAM_BOT_ENABLED=true
# WebApp URL (HTTPS shart). Bo'sh bo'lsa CLIENT_URL/bot-auth ishlatiladi.
TELEGRAM_BOT_WEBAPP_URL=https://dash.bayyina.org.uz/bot-auth
